# Copy this file to ".env" and fill in values as needed.
# The backend reads these via environment variables (Spring placeholders in application.yml).
#
# Quick start:
#   cp .env.example .env
#   set -a; source .env; set +a
#   ./mvnw spring-boot:run
#
# Or with a staging profile:
#   set -a; source .env; set +a
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=staging

DB_URL=jdbc:postgresql://localhost:5432/remit313
DB_HOST=localhost
DB_PORT=5432
DB_USER=apple
DB_PASS=backend

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=test
MAIL_PASS=password

SENDGRID_API_KEY=

JWT_SECRET=change-me
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

